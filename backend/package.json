    "normalize:bloom-widths": "node scripts/normalize-record-bloom-widths.js",
    "normalize:bloom-widths:dry-run": "node scripts/normalize-record-bloom-widths.js --dry-run",
    "backfill:file-names": "node scripts/backfill-file-names.js",
    "backfill:file-names:dry-run": "node scripts/backfill-file-names.js --dry-run",
    "backfill:garden-ids": "node scripts/backfill-garden-ids.js",
    "backfill:garden-ids:dry-run": "node scripts/backfill-garden-ids.js --dry-run",
    "backfill:photo-embeddings": "node scripts/backfill-photo-embeddings.js",
