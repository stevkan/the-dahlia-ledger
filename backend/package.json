  "dependencies": {
    "@azure/storage-blob": "^12.33.0",
    "@huggingface/transformers": "^4.2.0",
    "applicationinsights": "^3.15.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.9.0",
    "multer": "^2.1.1",
    "openai": "^6.37.0",
    "pg": "^8.22.0",
    "sharp": "^0.34.5",
