PORT=8787
APP_ENV=development
CORS_ORIGIN=http://localhost:5173

# OpenAI
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4.1-mini

# Firebase Admin
# In development, GOOGLE_APPLICATION_CREDENTIALS points to your local service account JSON file.
# setx GOOGLE_APPLICATION_CREDENTIALS "C:\path\to\service-account.json"
# In production, set APP_ENV=production and set GOOGLE_APPLICATION_CREDENTIALS to the
# single-line service account JSON value in your host's environment settings.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REQUIRE_FIREBASE_APP_CHECK=false

# Dev/test only: set to 127.0.0.1:9099 to route Admin SDK auth verification to a
# local Firebase Auth Emulator instead of production. firebase-admin auto-detects
# this var; no code change needed. Firestore/Storage stay on real production data.
FIREBASE_AUTH_EMULATOR_HOST=
# To let a bypass-emulator session see real data, add its email locally to
# GLOBAL_ADMIN_EMAILS below — this is a manual, local-only opt-in step.

# Azure Application Insights
# Paste the connection string from Azure Portal > Application Insights > Overview.
# Leave unset in development to disable telemetry.
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Optional: writable directory for cached CLIP model weights (photo identification/embeddings).
# Defaults to the OS temp dir, which is fine but re-downloads weights on every cold start/restart.
# Point this at persistent storage (e.g. /home/data/hf-cache on Azure App Service) to cache across restarts.
HF_CACHE_DIR=

# Comma-separated allowlists for app-wide administration.
# Use email for convenience, UID for maximum stability.
GLOBAL_ADMIN_EMAILS=you@example.com
GLOBAL_ADMIN_UIDS=
